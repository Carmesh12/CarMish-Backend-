DATABASE_URL="postgresql://user:pass@localhost:5432/dbname?sslmode=require"

# JWT
# JWT_SECRET="your-jwt-secret"

# Password reset
# This is the frontend URL that will receive the reset token.
# Example: https://your-frontend.com/reset-password
RESET_PASSWORD_BASE_URL="http://localhost:5173/reset-password"
# Can be any value supported by jsonwebtoken (e.g. "15m", "1h", "2d")
PASSWORD_RESET_TOKEN_EXPIRES="15m"

# SMTP (for nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="carvision489@gmail.com"
SMTP_PASS="vvtfkcpqcjjrhffi"
# Sender address used in outgoing reset emails
MAIL_FROM="CarMesh <carvision489@gmail.com>"

# Cloudinary (USER profile images)
# CLOUDINARY_PROFILE_FOLDER="carmesh/user-profiles"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
# Tripo OpenAPI (server-side only; never expose to the frontend)
TRIPO_API_KEY="your-tripo-api-key"
TRIPO_API_BASE_URL="https://api.tripo3d.ai/v2/openapi"
# H3 multiview model version (see Tripo docs)
TRIPO_MULTIVIEW_MODEL_VERSION="v3.1-20260211"

# 3D testing: skip Tripo and accept direct GLB upload (multipart field "model")
THREE_D_MOCK_MODE=false
# THREE_D_MOCK_MAX_MODEL_BYTES=104857600

# Supabase Storage — 3D models (GLB) only (S3-compatible API from Dashboard > Storage > S3)
# Create a PUBLIC bucket (e.g. vehicle-3d) so the viewer can load models without auth.
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_S3_ENDPOINT="https://YOUR_PROJECT_REF.storage.supabase.co/storage/v1/s3"
SUPABASE_S3_ACCESS_KEY_ID="your-s3-access-key-id"
SUPABASE_S3_SECRET_ACCESS_KEY="your-s3-secret-access-key"
SUPABASE_3D_BUCKET="vehicle-3d"
SUPABASE_3D_FOLDER="models"
SUPABASE_STORAGE_REGION="us-east-1"
# Set true only if bucket vehicle-3d is Public in Supabase Storage. Otherwise API returns signed URLs.
SUPABASE_3D_PUBLIC_BUCKET=false
# SUPABASE_3D_SIGNED_URL_TTL_SECONDS=604800
